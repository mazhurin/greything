# Initial config without SSL - for certbot
server {
    listen 80;
    server_name storage.greything.com;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location /health {
        proxy_pass http://127.0.0.1:8083;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}
